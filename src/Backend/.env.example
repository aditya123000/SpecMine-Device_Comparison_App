PORT=8000
CORS_ORIGIN=http://localhost:5173

# Default setup expected by the backend:
# host=localhost
# port=5432
# database=compare_devices
# user=postgres
#
# In most cases you only need to put your Postgres password below.
PGPASSWORD=your_postgres_password

# Optional overrides if your server uses a different host, port, database, or user
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=compare_devices
# PGUSER=postgres

# Set to true only if your hosted Postgres instance requires SSL
PG_SSL=false

# Auto-import devices from Data/db.json when the devices table is empty
AUTO_SEED_DB=true
