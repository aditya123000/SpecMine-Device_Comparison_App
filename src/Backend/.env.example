PORT=8000
CORS_ORIGIN=http://localhost:5173,https://your-site.netlify.app
JWT_SECRET=replace-with-a-long-random-secret

# Preferred for hosted databases like Supabase:
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
#
# Optional local Postgres setup if you are not using DATABASE_URL:
# host=localhost
# port=5432
# database=compare_devices
# user=postgres
PGPASSWORD=your_postgres_password

# Optional overrides if your server uses a different host, port, database, or user
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=compare_devices
# PGUSER=postgres

# Set to true for Supabase/most hosted Postgres providers
PG_SSL=true

# Auto-import devices from Data/db.json when the devices table is empty
AUTO_SEED_DB=true
